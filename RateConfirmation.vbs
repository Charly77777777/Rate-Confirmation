Sub SearchContact()
    name = InputBox("Enter name to search:", "Search Contact")
    found = False
    For i = 0 To 4
        If LCase(kontakt(i, 0)) = LCase(name) Then
            MsgBox "Found: " & kontakt(i, 0) & " - " & kontakt(i, 1), vbInformation
            found = True
            Exit For
        End If
    Next
    If Not found Then
        MsgBox "Contact not found!", vbExclamation
    End If
End Sub
