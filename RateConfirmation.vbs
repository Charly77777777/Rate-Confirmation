Dim kontakt(4, 1)
Dim i, choice, name, phone, found
Sub ShowMenu()
    choice = InputBox( _
        "Contact Manager" & vbCrLf & vbCrLf & _
        "1. Add Contact" & vbCrLf & _
        "2. View kontakt" & vbCrLf & _
        "3. Search Contact" & vbCrLf & _
        "4. Exit" & vbCrLf & vbCrLf & _
        "Enter your choice (1-4):", "Menu")
End Sub
Sub AddContact()
    For i = 0 To 4
        If kontakt(i, 0) = "" Then
            name = InputBox("Enter contact name:", "Add Contact")
            phone = InputBox("Enter phone number:", "Add Contact")
            kontakt(i, 0) = name
            kontakt(i, 1) = phone
            MsgBox "Contact added successfully!", vbInformation
            Exit Sub
        End If
    Next
    MsgBox "Contact list is full!", vbExclamation
End Sub
Sub Viewkontakt()
    Dim msg : msg = "kontakt List:" & vbCrLf & vbCrLf
    For i = 0 To 4
        If kontakt(i, 0) <> "" Then
            msg = msg & (i + 1) & ". " & kontakt(i, 0) & " - " & kontakt(i, 1) & vbCrLf
        End If
    Next
    MsgBox msg, vbInformation, "View kontakt"
End Sub
Do
    ShowMenu
    Select Case choice
        Case "1": AddContact
        Case "2": Viewkontakt
        Case "3": SearchContact
        Case "4": Exit Do
        Case Else: MsgBox "Invalid choice. Please select 1-4.", vbExclamation
    End Select
Loop
